# ─── OpenClaw Configuration — NVIDIA NIM ─────────────────────────────────────
#
# SETUP INSTRUCTIONS:
# 1. Copy this file:  cp .env.example .env
# 2. Replace NVIDIA_API_KEY below with your key from https://build.nvidia.com
# 3. Save the file — do NOT commit .env to git
#
# ─────────────────────────────────────────────────────────────────────────────

LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your-key-here
MODEL_VERSION=nvidia/llama-3.1-nemotron-ultra-253b-v1

# ─── Optional: Messaging Channels ────────────────────────────────────────────
# Uncomment and fill in to connect your agent to a messaging platform

# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# DISCORD_BOT_TOKEN=your-discord-bot-token
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token
